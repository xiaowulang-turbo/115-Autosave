---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { useDict } from '@/i18n';

const dict = useDict('zh');
const title = `隐私政策 · ${dict.brand}`;
const description = '115 Auto Save 不收集、存储、上传任何用户数据。';
---

<Base title={title} description={description} locale="zh">
  <Nav dict={dict} />
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24">
    <h1 class="text-4xl font-semibold tracking-tight">隐私政策</h1>
    <p class="mt-3 text-sm text-neutral-500">最后更新：2026 年 5 月 23 日</p>

    <div class="prose mt-12 space-y-8 text-[15px] leading-relaxed text-neutral-700 dark:text-neutral-300">
      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">概述</h2>
        <p class="mt-3">
          115 Auto Save（以下简称"本扩展"）是一款帮助用户自动完成 115 网盘分享页"输入访问码 → 转存 → 确认目录"操作的浏览器扩展。我们高度重视您的隐私。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">我们不收集的数据</h2>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li>不收集您的浏览历史、Cookie、登录凭据、文件内容或个人身份信息</li>
          <li>不向任何第三方服务器发送任何遥测、统计或诊断数据</li>
          <li>不使用任何分析工具（Google Analytics、Sentry 等）</li>
          <li>不读取除 <code>115cdn.com</code> 之外的任何网站内容</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">本扩展存储的数据</h2>
        <p class="mt-3">
          本扩展仅使用 Chrome 提供的 <code>chrome.storage.sync</code> API 存储以下用户偏好设置：
        </p>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li>是否启用自动转存</li>
          <li>三步操作各自的等待时长（毫秒）</li>
          <li>界面语言偏好（自动 / 中文 / 英文）</li>
          <li>主题偏好（自动 / 浅色 / 深色）</li>
        </ul>
        <p class="mt-3">
          以上数据完全存储在您的浏览器本地及您自己的 Google 账户同步空间中，开发者无法访问。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">权限说明</h2>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li><code>storage</code>：保存上述用户偏好设置</li>
          <li><code>host_permissions: https://115cdn.com/*</code>：在 115 网盘分享页注入自动化脚本</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">开源与可审查</h2>
        <p class="mt-3">
          本扩展全部源代码托管在
          <a href="https://github.com/xiaowulang-turbo/115-Autosave" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">GitHub</a>，任何人可自行审查、构建与发行。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">联系方式</h2>
        <p class="mt-3">
          如对本隐私政策有任何疑问，欢迎在
          <a href="https://github.com/xiaowulang-turbo/115-Autosave/issues" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">GitHub Issues</a>
          反馈。
        </p>
      </section>
    </div>
  </main>
  <Footer dict={dict} />
</Base>
