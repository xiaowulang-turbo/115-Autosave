---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { useDict } from '@/i18n';

const dict = useDict('en');
const title = `Privacy Policy · ${dict.brand}`;
const description = '115 Auto Save collects, stores and transmits zero user data.';
---

<Base title={title} description={description} locale="en">
  <Nav dict={dict} />
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24">
    <h1 class="text-4xl font-semibold tracking-tight">Privacy Policy</h1>
    <p class="mt-3 text-sm text-neutral-500">Last updated: May 23, 2026</p>

    <div class="prose mt-12 space-y-8 text-[15px] leading-relaxed text-neutral-700 dark:text-neutral-300">
      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Overview</h2>
        <p class="mt-3">
          115 Auto Save (the "Extension") is a browser extension that automates the
          "access code → save → confirm folder" flow on 115 share pages. We take your privacy seriously.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Data we do NOT collect</h2>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li>No browsing history, cookies, credentials, file contents or personally identifiable information</li>
          <li>No telemetry, analytics or diagnostic data sent to any server</li>
          <li>No third-party analytics tools (Google Analytics, Sentry, etc.)</li>
          <li>No access to websites other than <code>115cdn.com</code></li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Data the Extension stores</h2>
        <p class="mt-3">
          The Extension uses Chrome's <code>chrome.storage.sync</code> API to store these preferences only:
        </p>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li>Whether auto-save is enabled</li>
          <li>Per-step delays (in milliseconds)</li>
          <li>Interface language preference (auto / Chinese / English)</li>
          <li>Theme preference (auto / light / dark)</li>
        </ul>
        <p class="mt-3">
          All data lives in your local browser and your own Google sync account. The developer cannot access it.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Permissions</h2>
        <ul class="mt-3 list-disc space-y-2 pl-6">
          <li><code>storage</code>: store the preferences above</li>
          <li><code>host_permissions: https://115cdn.com/*</code>: inject the automation script on 115 share pages</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Open source & auditable</h2>
        <p class="mt-3">
          The full source code is published on
          <a href="https://github.com/xiaowulang-turbo/115-Autosave" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">GitHub</a> for anyone to review, build and distribute.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">Contact</h2>
        <p class="mt-3">
          Questions about this policy? Open an issue on
          <a href="https://github.com/xiaowulang-turbo/115-Autosave/issues" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">GitHub</a>.
        </p>
      </section>
    </div>
  </main>
  <Footer dict={dict} />
</Base>
