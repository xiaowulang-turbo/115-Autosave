---
import type { Dictionary } from '@/i18n/zh';
import { CHROME_WEB_STORE_URL, GREASY_FORK_URL } from '@/lib/constants';

interface Props {
  dict: Dictionary;
}

const { dict } = Astro.props;
const isStoreLive = CHROME_WEB_STORE_URL !== '#';
---

<section id="install" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
  <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{dict.install.title}</h2>

  <div class="mt-10 grid gap-4 sm:grid-cols-2">
    <article
      class="rounded-xl border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/[0.03] p-6"
    >
      <h3 class="text-lg font-semibold">{dict.install.extTitle}</h3>
      <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
        {dict.install.extDesc}
      </p>
      <a
        href={isStoreLive ? CHROME_WEB_STORE_URL : '#'}
        aria-disabled={!isStoreLive}
        class:list={[
          'mt-6 inline-flex h-10 items-center gap-2 rounded-lg px-4 text-sm font-medium transition',
          isStoreLive
            ? 'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)]'
            : 'cursor-not-allowed bg-neutral-200 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-500',
        ]}
      >
        {isStoreLive ? dict.install.extCta : dict.install.extPending}
      </a>
    </article>

    <article class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-800">
      <h3 class="text-lg font-semibold">{dict.install.scriptTitle}</h3>
      <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
        {dict.install.scriptDesc}
      </p>
      <a
        href={GREASY_FORK_URL}
        target="_blank"
        rel="noopener"
        class="mt-6 inline-flex h-10 items-center rounded-lg border border-neutral-200 px-4 text-sm font-medium text-neutral-700 transition hover:border-neutral-400 hover:text-neutral-900 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-neutral-600 dark:hover:text-neutral-100"
      >
        {dict.install.scriptCta}
      </a>
    </article>
  </div>
</section>
