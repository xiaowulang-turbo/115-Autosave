---
import type { Dictionary } from '@/i18n/zh';
import { CHROME_WEB_STORE_URL, GITHUB_URL } from '@/lib/constants';

interface Props {
  dict: Dictionary;
}

const { dict } = Astro.props;
const isStoreLive = CHROME_WEB_STORE_URL !== '#';
---

<section id="top" class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_0%,rgba(27,122,224,0.12),transparent_70%)] dark:bg-[radial-gradient(60%_50%_at_50%_0%,rgba(78,163,255,0.18),transparent_70%)]"
  >
  </div>

  <div class="mx-auto max-w-5xl px-4 pt-24 pb-20 sm:px-6 sm:pt-32 sm:pb-28">
    <div class="mx-auto max-w-3xl text-center">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-neutral-200 px-3 py-1 text-xs text-neutral-600 dark:border-neutral-800 dark:text-neutral-400"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
        {dict.hero.badge}
      </span>

      <h1 class="mt-6 text-4xl leading-[1.05] font-semibold tracking-tight whitespace-pre-line sm:text-6xl">
        {dict.hero.title}
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-base text-neutral-600 sm:text-lg dark:text-neutral-400">
        {dict.hero.desc}
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href={isStoreLive ? CHROME_WEB_STORE_URL : '#install'}
          class="inline-flex h-11 items-center gap-2 rounded-lg bg-[var(--color-accent)] px-5 text-sm font-medium text-white transition hover:bg-[var(--color-accent-hover)]"
        >
          {dict.hero.ctaPrimary}
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M9 7h8v8" />
          </svg>
        </a>
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex h-11 items-center rounded-lg border border-neutral-200 px-5 text-sm font-medium text-neutral-700 transition hover:border-neutral-400 hover:text-neutral-900 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-neutral-600 dark:hover:text-neutral-100"
        >
          {dict.hero.ctaSecondary}
        </a>
      </div>

      {
        !isStoreLive && (
          <p class="mt-4 text-xs text-neutral-500 dark:text-neutral-500">{dict.hero.pendingNote}</p>
        )
      }
    </div>
  </div>
</section>
