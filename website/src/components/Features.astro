---
import type { Dictionary } from '@/i18n/zh';

interface Props {
  dict: Dictionary;
}

const { dict } = Astro.props;
---

<section id="features" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
  <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{dict.features.title}</h2>

  <div class="mt-10 grid gap-4 sm:grid-cols-3">
    {
      dict.features.items.map((item) => (
        <article class="rounded-xl border border-neutral-200 bg-white p-6 transition hover:border-neutral-300 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-neutral-700">
          <h3 class="text-base font-semibold">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            {item.desc}
          </p>
        </article>
      ))
    }
  </div>
</section>

<section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6 sm:pb-24">
  <h2 class="text-xs font-medium tracking-[0.08em] text-neutral-500 uppercase">
    {dict.steps.title}
  </h2>
  <ol class="mt-6 grid gap-4 sm:grid-cols-3">
    {
      dict.steps.items.map((step) => (
        <li class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-800">
          <span class="font-mono text-xs tracking-widest text-[var(--color-accent)]">{step.num}</span>
          <h3 class="mt-3 text-base font-semibold">{step.title}</h3>
          <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{step.desc}</p>
        </li>
      ))
    }
  </ol>
</section>
