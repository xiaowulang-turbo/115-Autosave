---
import type { Dictionary } from '@/i18n/zh';

interface Props {
  dict: Dictionary;
}

const { dict } = Astro.props;
---

<section id="faq" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
  <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{dict.faq.title}</h2>

  <dl class="mt-10 divide-y divide-neutral-200 border-y border-neutral-200 dark:divide-neutral-800 dark:border-neutral-800">
    {
      dict.faq.items.map((item) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-medium">
            <span>{item.q}</span>
            <svg
              class="h-4 w-4 text-neutral-400 transition group-open:rotate-45"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 5v14M5 12h14" />
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">{item.a}</p>
        </details>
      ))
    }
  </dl>
</section>
